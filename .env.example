# 코어 게임은 환경변수가 필요 없습니다.
# 아래 값은 Supabase 리더보드를 연결할 때만 사용합니다.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# TAGO → Supabase 관리자 동기화용입니다. 브라우저에 절대 노출하지 마세요.
# GitHub Actions secret SUPABASE_URL / SUPABASE_SECRET_KEY로 각각 등록합니다.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx

# NAVER Web Dynamic Map의 공개 Client ID입니다. Client Secret은 절대 넣지 마세요.
# GitHub에서는 Actions repository variable VITE_NAVER_MAP_CLIENT_ID로 등록합니다.
VITE_NAVER_MAP_CLIENT_ID=

# TAGO는 공공데이터포털의 일반 인증키(Decoding)를 사용합니다.
# 로컬에서는 이 파일을 .env.local로 복사한 뒤 값을 넣으세요.
# GitHub에서는 파일에 넣지 말고 Actions secret TAGO_SERVICE_KEY로 등록하세요.
TAGO_SERVICE_KEY=
TAGO_CITY_CODES=11
TAGO_SYNC_DRY_RUN=true

# ODsay/TAGO 비밀 키는 프런트 VITE_* 변수에 넣지 마세요.
